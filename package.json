{
  "name": "codex-hud",
  "version": "0.0.0",
  "description": "Multiline local context HUD for Codex CLI sessions.",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "codex-hud": "./plugins/codex-hud/scripts/codex-hud.js"
  },
  "scripts": {
    "test": "node scripts/test-codex-hud.js && node scripts/test-codex-hud-config.js && node scripts/test-patched-codex-installer.js && node scripts/test-golden.js && node scripts/test-parsing-golden.js && node scripts/sync-release-version.js --check",
    "hud": "node plugins/codex-hud/scripts/codex-hud.js",
    "golden:update": "node scripts/test-golden.js --update && node scripts/test-parsing-golden.js --update",
    "build:rust": "cargo build --release --manifest-path rust/Cargo.toml",
    "test:rust": "node scripts/test-rust-golden.js && CODEX_HUD_BIN=$(pwd)/rust/target/release/codex-hud-rs node scripts/test-parsing-golden.js",
    "measure:rust": "node scripts/measure-rust-hud.js",
    "patch:codex": "node scripts/install-patched-codex.js",
    "patch:codex:dry-run": "node scripts/install-patched-codex.js --dry-run",
    "prepare": "husky",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run",
    "sync:version": "node scripts/sync-release-version.js",
    "vendor:toml": "node scripts/vendor-toml.js"
  },
  "keywords": [
    "codex",
    "hud",
    "statusline",
    "developer-tools"
  ],
  "author": "Brandon Wie",
  "repository": {
    "type": "git",
    "url": "https://github.com/brandonwie/codex-hud.git"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.3",
    "smol-toml": "^1.6.1"
  }
}
