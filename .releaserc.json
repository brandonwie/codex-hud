{
  "branches": [
    "main"
  ],
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node scripts/sync-release-version.js ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "package.json",
          "package-lock.json",
          "plugins/codex-hud/.codex-plugin/plugin.json",
          "rust/Cargo.toml",
          "rust/Cargo.lock",
          "site/index.html"
        ],
        "message": "chore(release): v${nextRelease.version} [skip ci]\n\n${nextRelease.notes}\n\nCo-authored-by: claude <noreply@anthropic.com>"
      }
    ],
    "@semantic-release/github"
  ]
}
